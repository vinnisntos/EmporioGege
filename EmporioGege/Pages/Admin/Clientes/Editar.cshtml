@page "{id:guid?}"
@model EmporioGege.Pages.Admin.Clientes.EditarModel
@{
    ViewData["Title"] = Model.Id is null ? "Novo Cliente" : "Editar Cliente";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-white fw-bold">@ViewData["Title"]</h1>
    <a asp-page="Index" class="btn btn-outline-light btn-sm"><i class="bi bi-arrow-left me-1"></i> Voltar</a>
</div>

@if (!string.IsNullOrEmpty(Model.MensagemErro))
{
    <div class="alert alert-danger">@Model.MensagemErro</div>
}

<form method="post" class="card card-custom p-4" style="max-width: 560px;">
    <div class="row g-3">
        <div class="col-12">
            <label asp-for="Nome" class="form-label small text-muted">Nome</label>
            <input asp-for="Nome" class="form-control" placeholder="Nome completo" />
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>

        <div class="col-12">
            <label asp-for="Telefone" class="form-label small text-muted">Telefone (opcional)</label>
            <input asp-for="Telefone" class="form-control" placeholder="(00) 00000-0000" />
        </div>

        <div class="col-12">
            <label asp-for="LimiteCredito" class="form-label small text-muted">Limite de crédito (fiado)</label>
            <input asp-for="LimiteCredito" type="number" step="0.01" min="0" class="form-control" />
            <span asp-validation-for="LimiteCredito" class="text-danger small"></span>
        </div>

        @if (Model.Id is not null)
        {
            <div class="col-12">
                <div class="text-muted small">Saldo devedor atual</div>
                <div class="fs-5 @(Model.SaldoDevedorAtual > 0 ? "text-warning" : "text-white")">@Model.SaldoDevedorAtual.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))</div>
                <div class="form-text text-muted">Ajustado automaticamente por vendas fiado e pagamentos — não editável aqui.</div>
            </div>
        }
    </div>

    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-warning fw-semibold px-4">Salvar</button>
        <a asp-page="Index" class="btn btn-outline-light">Cancelar</a>
    </div>
</form>
