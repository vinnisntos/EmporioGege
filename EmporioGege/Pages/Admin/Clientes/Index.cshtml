@page
@model EmporioGege.Pages.Admin.Clientes.IndexModel
@{
    ViewData["Title"] = "Clientes / Fiado";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 text-white fw-bold">Clientes / Fiado</h1>
        <p class="text-muted small mb-0">Cadastro de clientes e controle de crédito (PendurAi).</p>
    </div>
    <a asp-page="Editar" class="btn btn-warning fw-semibold">
        <i class="bi bi-person-plus me-1"></i> Novo Cliente
    </a>
</div>

@if (!string.IsNullOrEmpty(Model.MensagemSucesso))
{
    <div class="alert alert-success">@Model.MensagemSucesso</div>
}
@if (!string.IsNullOrEmpty(Model.MensagemErro))
{
    <div class="alert alert-danger">@Model.MensagemErro</div>
}

<div class="card card-custom p-3">
    @if (Model.Clientes.Count == 0)
    {
        <p class="text-muted text-center py-4 mb-0">Nenhum cliente cadastrado ainda.</p>
    }
    else
    {
        <table class="table table-dark table-borderless align-middle mb-0">
            <thead>
                <tr class="text-muted small text-uppercase">
                    <th>Cliente</th>
                    <th>Telefone</th>
                    <th>CPF/RG</th>
                    <th class="text-end">Limite</th>
                    <th class="text-end">Saldo devedor</th>
                    <th style="width:280px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Clientes)
                {
                    <tr>
                        <td class="text-white fw-medium">@c.Nome</td>
                        <td class="text-muted">@(c.Telefone ?? "—")</td>
                        <td class="text-muted">@(c.CpfRg ?? "—")</td>
                        <td class="text-end">@c.LimiteCredito.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))</td>
                        <td class="text-end @(c.SaldoDevedor > 0 ? "text-warning fw-semibold" : "text-muted")">@c.SaldoDevedor.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))</td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end align-items-center gap-2">
                                @if (c.SaldoDevedor > 0)
                                {
                                    <form method="post" asp-page-handler="RegistrarPagamento" class="d-flex align-items-center gap-1">
                                        <input type="hidden" name="id" value="@c.Id" />
                                        <input type="number" name="valor" step="0.01" min="0.01" max="@c.SaldoDevedor"
                                               class="form-control form-control-sm" style="width:110px;" placeholder="Valor" required />
                                        <button type="submit" class="btn btn-sm btn-outline-success">Receber</button>
                                    </form>
                                }
                                <a asp-page="Editar" asp-route-id="@c.Id" class="btn btn-sm btn-outline-light">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
