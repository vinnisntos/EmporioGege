@page "{id:guid?}"
@model EmporioGege.Pages.Admin.Estoque.EditarModel
@{
    ViewData["Title"] = Model.Id is null ? "Novo Produto" : "Editar Produto";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-white fw-bold">@ViewData["Title"]</h1>
    <a asp-page="Index" class="btn btn-outline-light btn-sm"><i class="bi bi-arrow-left me-1"></i> Voltar</a>
</div>

@if (!string.IsNullOrEmpty(Model.MensagemErro))
{
    <div class="alert alert-danger">@Model.MensagemErro</div>
}

<form method="post" class="card card-custom p-4" style="max-width: 760px;">
    <div class="row g-3">
        <div class="col-md-8">
            <label asp-for="Nome" class="form-label small text-muted">Nome do produto</label>
            <input asp-for="Nome" class="form-control" placeholder="Ex.: Cerveja Skol Lata 350ml" />
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="CodigoBarras" class="form-label small text-muted">Código de barras</label>
            <input asp-for="CodigoBarras" class="form-control" placeholder="EAN/UPC" />
        </div>

        <div class="col-md-4">
            <label asp-for="CustoMedio" class="form-label small text-muted">Custo médio</label>
            <input asp-for="CustoMedio" type="number" step="0.01" min="0" class="form-control" />
            <span asp-validation-for="CustoMedio" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="PrecoVendaBase" class="form-label small text-muted">Preço de venda (Balcão)</label>
            <input asp-for="PrecoVendaBase" type="number" step="0.01" min="0.01" class="form-control" />
            <span asp-validation-for="PrecoVendaBase" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="DataValidade" class="form-label small text-muted">Validade (opcional)</label>
            <input asp-for="DataValidade" type="date" class="form-control" />
        </div>

        <div class="col-md-3">
            <label asp-for="EstoqueAtual" class="form-label small text-muted">Estoque atual</label>
            <input asp-for="EstoqueAtual" type="number" min="0" class="form-control" />
            <span asp-validation-for="EstoqueAtual" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="EstoqueMinimo" class="form-label small text-muted">Estoque mínimo</label>
            <input asp-for="EstoqueMinimo" type="number" min="0" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="UnidadeMedida" class="form-label small text-muted">Unidade</label>
            <select asp-for="UnidadeMedida" class="form-select">
                <option value="Un">Unidade (Un)</option>
                <option value="Kg">Quilo (Kg)</option>
                <option value="L">Litro (L)</option>
            </select>
        </div>
        <div class="col-md-3">
            <label asp-for="QuantidadePorCaixa" class="form-label small text-muted">Unidades por caixa</label>
            <input asp-for="QuantidadePorCaixa" type="number" min="1" class="form-control" />
            <span asp-validation-for="QuantidadePorCaixa" class="text-danger small"></span>
        </div>

        <div class="col-12"><hr class="border-secondary opacity-25" /></div>

        <div class="col-12">
            <p class="text-muted small mb-2">Preços diferenciados (opcional — deixe em branco pra usar o preço de Balcão × unidades por caixa)</p>
        </div>
        <div class="col-md-6">
            <label asp-for="PrecoCaixa" class="form-label small text-muted">Preço da caixa fechada</label>
            <input asp-for="PrecoCaixa" type="number" step="0.01" min="0" class="form-control" placeholder="Auto (Balcão × Cx)" />
        </div>
        <div class="col-md-6">
            <label asp-for="PrecoAtacado" class="form-label small text-muted">Preço de atacado</label>
            <input asp-for="PrecoAtacado" type="number" step="0.01" min="0" class="form-control" placeholder="Auto (= Balcão)" />
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-warning fw-semibold px-4">Salvar</button>
        <a asp-page="Index" class="btn btn-outline-light">Cancelar</a>
    </div>
</form>
