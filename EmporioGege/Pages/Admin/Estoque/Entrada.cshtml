@page
@model EmporioGege.Pages.Admin.Estoque.EntradaModel
@{
    ViewData["Title"] = "Entrada de Estoque";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 text-white fw-bold">Entrada de Estoque</h1>
        <p class="text-muted small mb-0">Registre a chegada de mercadoria (compra/reposição) com rastro de auditoria.</p>
    </div>
    <a asp-page="Historico" class="btn btn-outline-light">
        <i class="bi bi-clock-history me-1"></i> Ver Histórico
    </a>
</div>

<div class="card card-custom p-4" style="max-width:640px;">
    <form method="post">
        <div asp-validation-summary="All" class="text-danger small mb-3"></div>

        <div class="mb-3">
            <label asp-for="ProdutoId" class="form-label small text-muted">Produto</label>
            <select asp-for="ProdutoId" class="form-select">
                <option value="">Selecione...</option>
                @foreach (var p in Model.Produtos)
                {
                    <option value="@p.Id">@p.Nome (estoque atual: @p.EstoqueAtual)</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="Quantidade" class="form-label small text-muted">Quantidade recebida</label>
            <input asp-for="Quantidade" type="number" min="1" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Justificativa" class="form-label small text-muted">Motivo / fornecedor (opcional)</label>
            <input asp-for="Justificativa" class="form-control" placeholder="Ex.: Compra fornecedor XYZ, NF 12345" />
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-warning fw-semibold">
                <i class="bi bi-box-arrow-in-down me-1"></i> Registrar Entrada
            </button>
            <a asp-page="Index" class="btn btn-outline-light">Cancelar</a>
        </div>
    </form>
</div>
