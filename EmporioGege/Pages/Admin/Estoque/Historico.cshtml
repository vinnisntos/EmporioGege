@page
@model EmporioGege.Pages.Admin.Estoque.HistoricoModel
@{
    ViewData["Title"] = "Histórico de Movimentação";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 text-white fw-bold">Histórico de Movimentação de Estoque</h1>
        <p class="text-muted small mb-0">Entradas, saídas por venda e ajustes manuais, em ordem cronológica.</p>
    </div>
    <a asp-page="Entrada" class="btn btn-warning fw-semibold">
        <i class="bi bi-box-arrow-in-down me-1"></i> Nova Entrada
    </a>
</div>

<form method="get" class="card card-custom p-3 mb-3">
    <div class="row g-3 align-items-end">
        <div class="col-auto">
            <label asp-for="De" class="form-label small text-muted">De</label>
            <input asp-for="De" type="date" class="form-control" />
        </div>
        <div class="col-auto">
            <label asp-for="Ate" class="form-label small text-muted">Até</label>
            <input asp-for="Ate" type="date" class="form-control" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-warning fw-semibold">Filtrar</button>
        </div>
        <div class="col-auto ms-auto d-flex gap-2">
            <a class="btn btn-outline-light btn-sm" href="?handler=ExportarXlsx&De=@Model.De&Ate=@Model.Ate"><i class="bi bi-file-earmark-excel me-1"></i>XLSX</a>
            <a class="btn btn-outline-light btn-sm" href="?handler=ExportarPdf&De=@Model.De&Ate=@Model.Ate"><i class="bi bi-file-earmark-pdf me-1"></i>PDF</a>
            <a class="btn btn-outline-light btn-sm" href="?handler=ExportarCsv&De=@Model.De&Ate=@Model.Ate"><i class="bi bi-filetype-csv me-1"></i>CSV</a>
            <a class="btn btn-outline-light btn-sm" href="?handler=ExportarXml&De=@Model.De&Ate=@Model.Ate"><i class="bi bi-file-earmark-code me-1"></i>XML</a>
        </div>
    </div>
</form>

<div class="card card-custom p-3">
    @if (Model.Movimentacoes.Count == 0)
    {
        <p class="text-muted text-center py-4 mb-0">Nenhuma movimentação encontrada no período selecionado.</p>
    }
    else
    {
        <table class="table table-dark table-borderless align-middle mb-0">
            <thead>
                <tr class="text-muted small text-uppercase">
                    <th>Data/Hora</th>
                    <th>Produto</th>
                    <th>Tipo</th>
                    <th class="text-end">Quantidade</th>
                    <th>Justificativa</th>
                    <th>Usuário</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model.Movimentacoes)
                {
                    var badgeClass = m.TipoMovimentacao switch
                    {
                        "ENTRADA_COMPRA" => "bg-success",
                        "SAIDA_VENDA" or "SAIDA_QUEBRA" or "SAIDA_DESCARTE" or "SAIDA_USO_INSUMO" => "bg-danger",
                        _ => "bg-warning text-dark"
                    };
                    var tipoLabel = m.TipoMovimentacao switch
                    {
                        "ENTRADA_COMPRA" => "Entrada (Compra)",
                        "SAIDA_VENDA" => "Saída (Venda)",
                        "AJUSTE_MANUAL" => "Ajuste Manual",
                        "SAIDA_QUEBRA" => "Saída (Quebra)",
                        "SAIDA_DESCARTE" => "Saída (Descarte)",
                        "SAIDA_USO_INSUMO" => "Saída (Uso como Insumo)",
                        _ => m.TipoMovimentacao
                    };
                    var quantidadeExibida = EmporioGege.Pages.Admin.Estoque.HistoricoModel.FormatarQuantidade(m.TipoMovimentacao, m.Quantidade);
                    var corQuantidade = quantidadeExibida.StartsWith('-') ? "text-danger" : "text-success";
                    <tr>
                        <td class="text-muted small">@m.DataMovimento.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-white fw-medium">@m.ProdutoNome</td>
                        <td><span class="badge @badgeClass">@tipoLabel</span></td>
                        <td class="text-end @corQuantidade fw-semibold">
                            @quantidadeExibida
                        </td>
                        <td class="text-muted small">@(m.Justificativa ?? "—")</td>
                        <td class="text-muted small">@(m.UsuarioNome ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
