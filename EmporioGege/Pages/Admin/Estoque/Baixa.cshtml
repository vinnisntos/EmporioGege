@page
@model EmporioGege.Pages.Admin.Estoque.BaixaModel
@{
    ViewData["Title"] = "Baixa Manual de Estoque";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 text-white fw-bold">Baixa Manual de Estoque</h1>
        <p class="text-muted small mb-0">Registre saída de estoque por quebra, descarte ou uso como insumo — só para produtos habilitados no cadastro.</p>
    </div>
    <a asp-page="Historico" class="btn btn-outline-light">
        <i class="bi bi-clock-history me-1"></i> Ver Histórico
    </a>
</div>

@if (!string.IsNullOrEmpty(Model.MensagemErro))
{
    <div class="alert alert-danger">@Model.MensagemErro</div>
}

@if (Model.Produtos.Count == 0)
{
    <div class="card card-custom p-4" style="max-width:640px;">
        <p class="text-muted mb-0">Nenhum produto habilitado para baixa manual ainda. Marque a opção "Permite baixa manual de estoque" no cadastro do produto (ex.: destilados usados como insumo em drinks) para que ele apareça aqui.</p>
        <a asp-page="Index" class="btn btn-outline-light mt-3">Ir para Produtos</a>
    </div>
}
else
{
    <div class="card card-custom p-4" style="max-width:640px;">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label asp-for="ProdutoId" class="form-label small text-muted">Produto</label>
                <select asp-for="ProdutoId" class="form-select">
                    <option value="">Selecione...</option>
                    @foreach (var p in Model.Produtos)
                    {
                        <option value="@p.Id">@p.Nome (estoque atual: @p.EstoqueAtual)</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Quantidade" class="form-label small text-muted">Quantidade</label>
                <input asp-for="Quantidade" type="number" min="1" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Motivo" class="form-label small text-muted">Motivo</label>
                <select asp-for="Motivo" class="form-select">
                    <option value="">Selecione...</option>
                    <option value="USO_INSUMO">Uso como Insumo</option>
                    <option value="QUEBRA">Quebra</option>
                    <option value="DESCARTE">Descarte</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Justificativa" class="form-label small text-muted">Justificativa</label>
                <textarea asp-for="Justificativa" class="form-control" rows="2" placeholder="Ex.: garrafa quebrada ao repor prateleira / usada em drink de degustação no balcão"></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning fw-semibold">
                    <i class="bi bi-box-arrow-up me-1"></i> Registrar Baixa
                </button>
                <a asp-page="Index" class="btn btn-outline-light">Cancelar</a>
            </div>
        </form>
    </div>
}
