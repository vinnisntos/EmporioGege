@page
@model EmporioGege.Pages.Admin.Estoque.IndexModel
@{
    ViewData["Title"] = "Estoque / Produtos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 text-white fw-bold">Estoque / Produtos</h1>
        <p class="text-muted small mb-0">Cadastro de produtos, preços e controle de estoque.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="Historico" class="btn btn-outline-light">
            <i class="bi bi-clock-history me-1"></i> Histórico
        </a>
        <a asp-page="Entrada" class="btn btn-outline-light">
            <i class="bi bi-box-arrow-in-down me-1"></i> Entrada de Estoque
        </a>
        <a asp-page="Baixa" class="btn btn-outline-light">
            <i class="bi bi-box-arrow-up me-1"></i> Baixa Manual
        </a>
        <a asp-page="Editar" class="btn btn-warning fw-semibold">
            <i class="bi bi-plus-circle me-1"></i> Novo Produto
        </a>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.MensagemSucesso))
{
    <div class="alert alert-success">@Model.MensagemSucesso</div>
}

@if (!string.IsNullOrEmpty(Model.MensagemErro))
{
    <div class="alert alert-danger">@Model.MensagemErro</div>
}

<div class="card card-custom p-3">
    @if (Model.Produtos.Count == 0)
    {
        <p class="text-muted text-center py-4 mb-0">Nenhum produto cadastrado ainda. Clique em "Novo Produto" para começar.</p>
    }
    else
    {
        <div class="mb-3">
            <input type="text" id="busca-estoque" class="form-control" autocomplete="off"
                   placeholder="Buscar por nome ou código de barras..." />
        </div>
        <p id="busca-sem-resultado" class="text-muted text-center py-4 mb-0 d-none">Nenhum produto encontrado.</p>
        <table class="table table-dark table-borderless align-middle mb-0" id="tabela-estoque">
            <thead>
                <tr class="text-muted small text-uppercase">
                    <th>Produto</th>
                    <th>Código de Barras</th>
                    <th class="text-end">Preço</th>
                    <th class="text-center">Estoque</th>
                    <th class="text-center">Status</th>
                    <th style="width:160px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Produtos)
                {
                    var estoqueCritico = p.EstoqueAtual <= p.EstoqueMinimo;
                    <tr class="@(p.Ativo ? "" : "opacity-50")" data-busca="@($"{p.Nome} {p.CodigoBarras}".ToLowerInvariant())">
                        <td>
                            <div class="fw-medium text-white">@p.Nome</div>
                            <div class="text-muted small">@p.UnidadeMedida @(p.QuantidadePorCaixa > 1 ? $"· Cx com {p.QuantidadePorCaixa}" : "")</div>
                        </td>
                        <td class="text-muted">@(p.CodigoBarras ?? "—")</td>
                        <td class="text-end">@p.PrecoVendaBase.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))</td>
                        <td class="text-center">
                            <span class="@(estoqueCritico ? "text-danger fw-semibold" : "text-white")">@p.EstoqueAtual</span>
                            <span class="text-muted small"> / mín. @p.EstoqueMinimo</span>
                        </td>
                        <td class="text-center">
                            @if (p.Ativo)
                            {
                                <span class="badge bg-success">Ativo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inativo</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-page="Editar" asp-route-id="@p.Id" class="btn btn-sm btn-outline-light me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" asp-page-handler="AlternarAtivo" class="d-inline">
                                <input type="hidden" name="id" value="@p.Id" />
                                <input type="hidden" name="ativoAtual" value="@(p.Ativo.ToString())" />
                                <button type="submit" class="btn btn-sm @(p.Ativo ? "btn-outline-danger" : "btn-outline-success")">
                                    @(p.Ativo ? "Desativar" : "Reativar")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@section Scripts {
    <script>
        (function () {
            const input = document.getElementById('busca-estoque');
            if (!input) return;

            const linhas = Array.from(document.querySelectorAll('#tabela-estoque tbody tr'));
            const semResultado = document.getElementById('busca-sem-resultado');

            input.addEventListener('input', function () {
                const termo = input.value.trim().toLowerCase();
                let visiveis = 0;

                linhas.forEach(function (linha) {
                    const confere = linha.dataset.busca.includes(termo);
                    linha.classList.toggle('d-none', !confere);
                    if (confere) visiveis++;
                });

                semResultado.classList.toggle('d-none', visiveis > 0);
            });

            input.focus();
        })();
    </script>
}
