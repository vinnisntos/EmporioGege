@page
@model EmporioGege.Pages.Admin.ProdutosMaisVendidos.IndexModel
@{
    ViewData["Title"] = "Produtos Mais Vendidos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 text-white fw-bold">Produtos Mais Vendidos</h1>
        <p class="text-muted small mb-0">Ranking por quantidade vendida no período (top 20).</p>
    </div>
</div>

<form method="get" class="card card-custom p-3 mb-3">
    <div class="row g-3 align-items-end">
        <div class="col-auto">
            <label asp-for="De" class="form-label small text-muted">De</label>
            <input asp-for="De" type="date" class="form-control" />
        </div>
        <div class="col-auto">
            <label asp-for="Ate" class="form-label small text-muted">Até</label>
            <input asp-for="Ate" type="date" class="form-control" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-warning fw-semibold">Filtrar</button>
        </div>
        <div class="col-auto ms-auto d-flex gap-2">
            <a class="btn btn-outline-light btn-sm" href="?handler=ExportarXlsx&De=@Model.De&Ate=@Model.Ate"><i class="bi bi-file-earmark-excel me-1"></i>XLSX</a>
            <a class="btn btn-outline-light btn-sm" href="?handler=ExportarPdf&De=@Model.De&Ate=@Model.Ate"><i class="bi bi-file-earmark-pdf me-1"></i>PDF</a>
            <a class="btn btn-outline-light btn-sm" href="?handler=ExportarCsv&De=@Model.De&Ate=@Model.Ate"><i class="bi bi-filetype-csv me-1"></i>CSV</a>
            <a class="btn btn-outline-light btn-sm" href="?handler=ExportarXml&De=@Model.De&Ate=@Model.Ate"><i class="bi bi-file-earmark-code me-1"></i>XML</a>
        </div>
    </div>
</form>

<div class="card card-custom p-3">
    @if (Model.Produtos.Count == 0)
    {
        <p class="text-muted text-center py-4 mb-0">Nenhuma venda encontrada no período selecionado.</p>
    }
    else
    {
        <table class="table table-dark table-borderless align-middle mb-0">
            <thead>
                <tr class="text-muted small text-uppercase">
                    <th style="width:50px;">#</th>
                    <th>Produto</th>
                    <th class="text-end">Quantidade Vendida</th>
                    <th class="text-end">Total Vendido</th>
                </tr>
            </thead>
            <tbody>
                @for (var i = 0; i < Model.Produtos.Count; i++)
                {
                    var p = Model.Produtos[i];
                    <tr>
                        <td class="text-muted">@(i + 1)</td>
                        <td class="text-white fw-medium">@p.Nome</td>
                        <td class="text-end text-white">@p.QuantidadeVendida</td>
                        <td class="text-end text-white fw-medium">@p.TotalVendido.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
