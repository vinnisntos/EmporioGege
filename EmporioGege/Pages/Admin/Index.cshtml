@page
@model EmporioGege.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Painel Administrativo";
    Layout = "_Layout";
}

<div class="container-fluid p-0">
    <!-- Cabeçalho de Boas-Vindas -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-white fw-bold">Visão Geral do Negócio</h1>
            <p class="text-muted small mb-0">Monitore o faturamento, estoque e contas pendentes da adega.</p>
        </div>
        <button class="btn btn-sm btn-outline-warning d-flex align-items-center gap-2" onclick="window.location.reload();">
            <i class="bi bi-arrow-clockwise"></i> Atualizar Dados
        </button>
    </div>

    <!-- Grid de Métricas Principais (UX Cards) -->
    <div class="row g-3 mb-4">
        <!-- Card 1: Faturamento -->
        <div class="col-xl-3 col-sm-6">
            <div class="card card-custom h-100 p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="text-muted small fw-medium text-uppercase">Faturamento (Hoje)</span>
                    <div class="p-2 bg-success bg-opacity-10 text-success rounded-3">
                        <i class="bi bi-cash-coin fs-4"></i>
                    </div>
                </div>
                <h3 class="fw-bold text-white mb-1">@Model.FaturamentoHoje.ToString("C")</h3>
                <span class="text-success small fw-medium"><i class="bi bi-graph-up me-1"></i> Caixa em operação</span>
            </div>
        </div>

        <!-- Card 2: Fiado / Penduras -->
        <div class="col-xl-3 col-sm-6">
            <div class="card card-custom h-100 p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="text-muted small fw-medium text-uppercase">Total no PendurAi</span>
                    <div class="p-2 bg-warning bg-opacity-10 text-warning rounded-3">
                        <i class="bi bi-person-exclamation fs-4"></i>
                    </div>
                </div>
                <h3 class="fw-bold text-white mb-1">@Model.FiadoPendenteTotal.ToString("C")</h3>
                <span class="text-muted small">Carteira ativa de clientes</span>
            </div>
        </div>

        <!-- Card 3: Estoque Crítico -->
        <div class="col-xl-3 col-sm-6">
            <div class="card card-custom h-100 p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="text-muted small fw-medium text-uppercase">Alertas de Estoque</span>
                    <div class="p-2 bg-danger bg-opacity-10 text-danger rounded-3">
                        <i class="bi bi-box-seam-fill fs-4"></i>
                    </div>
                </div>
                <h3 class="fw-bold text-white mb-1">@Model.AlertasEstoqueCritico</h3>
                <span class="text-danger small fw-medium">
                    <a asp-page="/Admin/Estoque" class="text-danger text-decoration-none">Ver itens abaixo do mínimo →</a>
                </span>
            </div>
        </div>

        <!-- Card 4: Comandas em Aberto -->
        <div class="col-xl-3 col-sm-6">
            <div class="card card-custom h-100 p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="text-muted small fw-medium text-uppercase">Comandas Ativas</span>
                    <div class="p-2 bg-info bg-opacity-10 text-info rounded-3">
                        <i class="bi bi-receipt fs-4"></i>
                    </div>
                </div>
                <h3 class="fw-bold text-white mb-1">@Model.ComandasAtivasContador</h3>
                <span class="text-info small fw-medium">Consumo local no balcão</span>
            </div>
        </div>
    </div>

    <!-- Seção Inferior: Atalhos Rápidos e Gráficos Futuros -->
    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card card-custom p-4 h-100">
                <h5 class="text-white fw-semibold mb-3">Ações Administrativas Rápidas</h5>
                <div class="row g-2">
                    <div class="col-sm-4">
                        <a asp-page="/Admin/Estoque" class="btn btn-outline-light w-100 py-3 text-start d-flex align-items-center gap-2" style="border-color: rgba(255,255,255,0.08); background: rgba(255,255,255,0.02)">
                            <i class="bi bi-plus-circle text-warning"></i> Novo Produto / Grade
                        </a>
                    </div>
                    <div class="col-sm-4">
                        <a asp-page="/Admin/Clientes" class="btn btn-outline-light w-100 py-3 text-start d-flex align-items-center gap-2" style="border-color: rgba(255,255,255,0.08); background: rgba(255,255,255,0.02)">
                            <i class="bi bi-person-plus text-warning"></i> Autorizar Crédito / Fiado
                        </a>
                    </div>
                    <div class="col-sm-4">
                        <a asp-page="/Admin/Funcionarios" class="btn btn-outline-light w-100 py-3 text-start d-flex align-items-center gap-2" style="border-color: rgba(255,255,255,0.08); background: rgba(255,255,255,0.02)">
                            <i class="bi bi-shield-plus text-warning"></i> Configurar Operador
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card card-custom p-4 h-100 text-center d-flex flex-column justify-content-center align-items-center">
                <div class="text-muted border border-secondary border-opacity-25 rounded-circle p-3 mb-2" style="width:fit-content">
                    <i class="bi bi-bar-chart-line fs-3 text-warning"></i>
                </div>
                <h6 class="text-white fw-medium mb-1">Módulo Analítico</h6>
                <p class="text-muted small px-3 mb-0">Gráficos de volumetria e curva ABC de bebidas serão renderizados aqui.</p>
            </div>
        </div>
    </div>
</div>