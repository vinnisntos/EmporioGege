@page
@model EmporioGege.Pages.Admin.Funcionarios.IndexModel
@{
    ViewData["Title"] = "Funcionários";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 text-white fw-bold">Funcionários</h1>
        <p class="text-muted small mb-0">Contas de acesso ao sistema (vendedor/caixa e administrador).</p>
    </div>
    <a asp-page="Editar" class="btn btn-warning fw-semibold">
        <i class="bi bi-person-plus me-1"></i> Novo Funcionário
    </a>
</div>

<div class="card card-custom p-3">
    @if (Model.Funcionarios.Count == 0)
    {
        <p class="text-muted text-center py-4 mb-0">Nenhum funcionário cadastrado além de você.</p>
    }
    else
    {
        <table class="table table-dark table-borderless align-middle mb-0">
            <thead>
                <tr class="text-muted small text-uppercase">
                    <th>Nome</th>
                    <th>E-mail</th>
                    <th>Cargo</th>
                    <th style="width:80px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in Model.Funcionarios)
                {
                    <tr>
                        <td class="text-white fw-medium">@f.Nome</td>
                        <td class="text-muted">@f.Email</td>
                        <td>
                            <span class="badge @(f.Role == "administrador" ? "bg-warning text-dark" : "bg-info text-dark")">
                                @(f.Role == "administrador" ? "Administrador" : "Vendedor / Caixa")
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-page="Editar" asp-route-id="@f.Id" class="btn btn-sm btn-outline-light">
                                <i class="bi bi-pencil"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
