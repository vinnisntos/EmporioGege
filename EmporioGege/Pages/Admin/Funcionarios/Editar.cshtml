@page "{id:guid?}"
@model EmporioGege.Pages.Admin.Funcionarios.EditarModel
@{
    ViewData["Title"] = Model.Id is null ? "Novo Funcionário" : "Editar Funcionário";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-white fw-bold">@ViewData["Title"]</h1>
    <a asp-page="Index" class="btn btn-outline-light btn-sm"><i class="bi bi-arrow-left me-1"></i> Voltar</a>
</div>

@if (!string.IsNullOrEmpty(Model.MensagemErro))
{
    <div class="alert alert-danger">@Model.MensagemErro</div>
}

<form method="post" class="card card-custom p-4" style="max-width: 560px;">
    <div class="row g-3">
        <div class="col-12">
            <label asp-for="Nome" class="form-label small text-muted">Nome</label>
            <input asp-for="Nome" class="form-control" placeholder="Nome completo" />
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>

        <div class="col-12">
            <label asp-for="Email" class="form-label small text-muted">E-mail (login)</label>
            <input asp-for="Email" type="email" class="form-control" readonly="@(Model.Id is not null)" />
            <span asp-validation-for="Email" class="text-danger small"></span>
            @if (Model.Id is not null)
            {
                <div class="form-text text-muted">O e-mail de login não pode ser alterado por aqui.</div>
            }
        </div>

        @if (Model.Id is null)
        {
            <div class="col-12">
                <label asp-for="Senha" class="form-label small text-muted">Senha inicial</label>
                <input asp-for="Senha" type="password" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Senha" class="text-danger small"></span>
                <div class="form-text text-muted">O funcionário pode trocar depois de fazer login.</div>
            </div>
        }

        <div class="col-12">
            <label asp-for="Role" class="form-label small text-muted">Cargo</label>
            <select asp-for="Role" class="form-select">
                <option value="vendedor">Vendedor / Caixa</option>
                <option value="administrador">Administrador</option>
            </select>
            <span asp-validation-for="Role" class="text-danger small"></span>
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-warning fw-semibold px-4">Salvar</button>
        <a asp-page="Index" class="btn btn-outline-light">Cancelar</a>
    </div>
</form>
