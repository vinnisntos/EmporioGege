@page
@model EmporioGege.Pages.Caixa.Turno.IndexModel
@{
    ViewData["Title"] = "Controle de Turno";
}

<h4 class="mb-3"><i class="bi bi-clock-history me-2"></i>Controle de Turno</h4>

@if (!string.IsNullOrEmpty(Model.MensagemErro))
{
    <div class="alert alert-danger">@Model.MensagemErro</div>
}
@if (!string.IsNullOrEmpty(Model.MensagemSucesso))
{
    <div class="alert alert-success">@Model.MensagemSucesso</div>
}

@if (Model.ResultadoFechamento is not null)
{
    var r = Model.ResultadoFechamento;
    var quebrou = r.Diferenca != 0;
    <div class="card-custom p-4 mb-4 border @(quebrou ? "border-danger" : "border-success")">
        <h5 class="mb-3">Turno fechado</h5>
        <div class="row g-3">
            <div class="col-6 col-md-3">
                <div class="text-muted small">Saldo inicial</div>
                <div class="fs-5">@r.SaldoInicial.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="text-muted small">Créditos (suprimentos)</div>
                <div class="fs-5 text-success">+@r.TotalCreditos.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="text-muted small">Débitos (sangrias)</div>
                <div class="fs-5 text-danger">-@r.TotalDebitos.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="text-muted small">Saldo sistema</div>
                <div class="fs-5">@r.SaldoSistema.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))</div>
            </div>
        </div>
        <hr />
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <div class="text-muted small">Saldo informado (contagem física)</div>
                <div class="fs-4">@r.SaldoInformado.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))</div>
            </div>
            <div class="text-end">
                <div class="text-muted small">Diferença</div>
                <div class="fs-3 fw-bold @(quebrou ? "text-danger" : "text-success")">
                    @(r.Diferenca > 0 ? "+" : "")@r.Diferenca.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))
                </div>
                @if (quebrou)
                {
                    <div class="small text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Quebra de caixa detectada</div>
                }
            </div>
        </div>
    </div>
}

@if (Model.TurnoAtual is null)
{
    <div class="card-custom p-4" style="max-width:420px;">
        <h5 class="mb-3">Abrir turno</h5>
        <form method="post" asp-page-handler="Abrir">
            <div class="mb-3">
                <label class="form-label small text-muted">Saldo inicial em caixa</label>
                <input type="number" step="0.01" min="0" class="form-control" asp-for="SaldoInicialInput" />
            </div>
            <button type="submit" class="btn btn-warning w-100 fw-semibold">Abrir turno</button>
        </form>
    </div>
}
else
{
    <div class="card-custom p-4 mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <span class="badge bg-success mb-2">TURNO ABERTO</span>
                <div class="text-muted small">Aberto em @Model.TurnoAtual.DataAbertura.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                <div class="fs-5">Saldo inicial: @Model.TurnoAtual.SaldoInicial.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card-custom p-4 h-100">
                <h6 class="mb-3">Sangria / Suprimento</h6>
                <form method="post" asp-page-handler="Lancamento">
                    <div class="mb-2">
                        <select class="form-select" asp-for="TipoLancamento">
                            <option value="SANGRIA">Sangria (retirada)</option>
                            <option value="SUPRIMENTO">Suprimento (reforço)</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <input type="number" step="0.01" min="0.01" class="form-control" placeholder="Valor" asp-for="ValorLancamento" />
                    </div>
                    <div class="mb-3">
                        <input type="text" class="form-control" placeholder="Motivo" asp-for="MotivoLancamento" />
                    </div>
                    <button type="submit" class="btn btn-outline-warning w-100">Registrar</button>
                </form>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card-custom p-4 h-100">
                <h6 class="mb-3">Fechar turno</h6>
                <form method="post" asp-page-handler="Fechar">
                    <div class="mb-3">
                        <label class="form-label small text-muted">Saldo contado no caixa</label>
                        <input type="number" step="0.01" min="0" class="form-control" asp-for="SaldoInformadoInput" />
                    </div>
                    <button type="submit" class="btn btn-danger w-100 fw-semibold"
                            onclick="return confirm('Confirma o fechamento do turno? Essa ação não pode ser desfeita.');">
                        Fechar turno
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="card-custom p-4 mt-4">
        <h6 class="mb-3">Lançamentos deste turno</h6>
        @if (Model.Lancamentos.Count == 0)
        {
            <div class="text-muted small">Nenhum lançamento registrado ainda.</div>
        }
        else
        {
            <table class="table table-dark table-borderless align-middle mb-0">
                <thead>
                    <tr class="text-muted small text-uppercase">
                        <th>Data</th>
                        <th>Tipo</th>
                        <th>Motivo</th>
                        <th class="text-end">Valor</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var l in Model.Lancamentos)
                    {
                        <tr>
                            <td>@l.CriadoEm.ToLocalTime().ToString("dd/MM HH:mm")</td>
                            <td>
                                @if (l.TipoOperacao == "CREDITO")
                                {
                                    <span class="badge bg-success">SUPRIMENTO</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">SANGRIA</span>
                                }
                            </td>
                            <td>@l.Motivo</td>
                            <td class="text-end">@l.Valor.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}
