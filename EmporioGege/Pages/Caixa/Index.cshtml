@page
@using System.Text.Json
@model EmporioGege.Pages.Caixa.IndexModel
@{
    ViewData["Title"] = "Frente de Caixa / PDV";
    var opcoesJson = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var catalogoJson = JsonSerializer.Serialize(Model.Produtos, opcoesJson);
    var precosJson = JsonSerializer.Serialize(Model.PrecosDiferenciados, opcoesJson);
    var clientesJson = JsonSerializer.Serialize(Model.Clientes, opcoesJson);
}

<style>
    #pdv-wrapper { display: grid; grid-template-columns: 1fr 380px; gap: 1.5rem; align-items: start; }

    .pdv-badge {
        display: inline-flex; align-items: center; gap: .5rem;
        padding: .5rem 1rem; border-radius: 999px; font-weight: 600; font-size: .85rem;
        letter-spacing: .3px; cursor: pointer; user-select: none; transition: all .15s ease;
        border: 1px solid transparent;
    }
    .pdv-badge.fiscal { background: rgba(13, 202, 240, .12); border-color: rgba(13, 202, 240, .4); color: #6fe4ff; }
    .pdv-badge.interno { background: rgba(255, 152, 0, .12); border-color: rgba(255, 152, 0, .4); color: #ffb74d; }

    #busca-produto { font-size: 1.1rem; padding: .75rem 1rem; }

    #sugestoes-produto {
        position: absolute; z-index: 20; width: 100%; max-height: 280px; overflow-y: auto;
        background: #17171d; border: 1px solid rgba(255,255,255,.08); border-radius: .5rem;
        margin-top: .25rem; display: none;
    }
    #sugestoes-produto .item-sugestao { padding: .6rem 1rem; cursor: pointer; }
    #sugestoes-produto .item-sugestao:hover, #sugestoes-produto .item-sugestao.ativo { background: rgba(255,193,7,.1); }

    #carrinho-corpo tr td { vertical-align: middle; }
    .total-venda { font-size: 2rem; font-weight: 700; color: #ffc107; }

    .atalho-hint {
        font-size: .7rem; color: #6c757d; border: 1px solid rgba(255,255,255,.1);
        border-radius: 4px; padding: 1px 6px; margin-left: 6px;
    }

    #toast-container { position: fixed; top: 1rem; right: 1rem; z-index: 1080; }
</style>

@if (Model.SemTenant)
{
    <div class="alert alert-warning">
        Este usuário não está vinculado a uma loja (tenant). O PDV só pode ser operado por usuários de uma loja específica.
    </div>
    return;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-cpu-fill me-2"></i>Frente de Caixa</h4>
    <div id="badge-tipo-venda" class="pdv-badge fiscal" title="Alternar com F2">
        <i class="bi bi-file-earmark-check"></i>
        <span id="badge-tipo-venda-texto">COM NOTA FISCAL</span>
        <span class="atalho-hint">F2</span>
    </div>
</div>

<div id="pdv-wrapper">
    <div>
        <div class="position-relative mb-3">
            <input type="text" id="busca-produto" class="form-control" autocomplete="off"
                   placeholder="Bipar código de barras ou buscar por nome... (F8)" />
            <div id="sugestoes-produto"></div>
        </div>

        <div class="card-custom p-3">
            <table class="table table-dark table-borderless align-middle mb-0">
                <thead>
                    <tr class="text-muted small text-uppercase">
                        <th>Produto</th>
                        <th class="text-center" style="width:90px;">Un/Cx</th>
                        <th class="text-center" style="width:120px;">Qtd.</th>
                        <th class="text-end" style="width:120px;">Preço</th>
                        <th class="text-end" style="width:120px;">Subtotal</th>
                        <th style="width:40px;"></th>
                    </tr>
                </thead>
                <tbody id="carrinho-corpo">
                    <tr id="carrinho-vazio">
                        <td colspan="6" class="text-center text-muted py-4">Nenhum item no carrinho. Bipe um produto para começar.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card-custom p-3">
        <div class="d-flex justify-content-between text-muted small mb-2">
            <span>Itens no carrinho</span>
            <span id="resumo-itens">0</span>
        </div>
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="text-muted">Total</span>
            <span class="total-venda" id="total-venda">R$ 0,00</span>
        </div>

        <label class="form-label small text-muted">Método de pagamento</label>
        <select id="metodo-pagamento" class="form-select mb-3">
            <option value="DINHEIRO">Dinheiro</option>
            <option value="DEBITO">Cartão de Débito</option>
            <option value="CREDITO">Cartão de Crédito</option>
            <option value="PIX">Pix</option>
            <option value="FIADO">Fiado (PendurAi)</option>
        </select>

        <div id="bloco-cliente-fiado" class="mb-3" style="display:none;">
            <label class="form-label small text-muted">Cliente</label>
            <select id="cliente-fiado" class="form-select">
                <option value="">Selecione um cliente...</option>
                @foreach (var c in Model.Clientes)
                {
                    <option value="@c.Id">@c.Nome (deve @c.SaldoDevedor.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR")) de @c.LimiteCredito.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR")))</option>
                }
            </select>
            @if (Model.Clientes.Count == 0)
            {
                <div class="form-text text-warning">Nenhum cliente cadastrado — cadastre em Clientes antes de vender fiado.</div>
            }
        </div>

        <button type="button" id="btn-finalizar" class="btn btn-warning w-100 fw-semibold py-2">
            Finalizar Venda <span class="atalho-hint">F10</span>
        </button>
    </div>
</div>

<div id="toast-container"></div>

@Html.AntiForgeryToken()

<script>
(function () {
    const catalogo = @Html.Raw(catalogoJson);
    const precosDiferenciados = @Html.Raw(precosJson);
    const carrinho = new Map(); // produtoId -> { produto, quantidade, tipoPreco }

    // Preço exibido no PDV é só uma prévia — o servidor sempre recalcula a partir de
    // precos_produto/preco_venda_base no VendaService, nunca confia no que vem daqui.
    function precoParaTipo(produto, tipoPreco) {
        if (tipoPreco === 'CAIXA') {
            const configurado = precosDiferenciados.find(p => p.produtoId === produto.id && p.tipoPreco === 'CAIXA');
            return configurado ? configurado.valor : produto.precoVendaBase * (produto.quantidadePorCaixa || 1);
        }
        return produto.precoVendaBase;
    }

    function fatorConversao(produto, tipoPreco) {
        return tipoPreco === 'CAIXA' ? (produto.quantidadePorCaixa || 1) : 1;
    }

    const buscaInput = document.getElementById('busca-produto');
    const sugestoesEl = document.getElementById('sugestoes-produto');
    const carrinhoCorpo = document.getElementById('carrinho-corpo');
    const carrinhoVazioRow = document.getElementById('carrinho-vazio');
    const resumoItens = document.getElementById('resumo-itens');
    const totalVendaEl = document.getElementById('total-venda');
    const badgeTipoVenda = document.getElementById('badge-tipo-venda');
    const badgeTipoVendaTexto = document.getElementById('badge-tipo-venda-texto');
    const btnFinalizar = document.getElementById('btn-finalizar');
    const metodoPagamentoSelect = document.getElementById('metodo-pagamento');
    const blocoClienteFiado = document.getElementById('bloco-cliente-fiado');
    const clienteFiadoSelect = document.getElementById('cliente-fiado');
    const antiforgeryToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

    let emitirNotaFiscal = true;
    let sugestaoAtiva = -1;

    metodoPagamentoSelect.addEventListener('change', () => {
        blocoClienteFiado.style.display = metodoPagamentoSelect.value === 'FIADO' ? 'block' : 'none';
    });

    function formatarMoeda(valor) {
        return valor.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
    }

    // Nome/código de barras do produto são texto livre cadastrado pelo lojista, e
    // mensagens de erro do servidor também acabam indo para innerHTML — sem isso,
    // um produto chamado por exemplo `<img src=x onerror=alert(1)>` executaria no PDV.
    function escapeHtml(texto) {
        const div = document.createElement('div');
        div.textContent = texto ?? '';
        return div.innerHTML;
    }

    function mostrarToast(mensagem, tipo) {
        const cor = tipo === 'erro' ? 'bg-danger' : tipo === 'aviso' ? 'bg-warning text-dark' : 'bg-success';
        const toast = document.createElement('div');
        toast.className = `toast align-items-center text-white ${cor} border-0 mb-2 show`;
        toast.innerHTML = `<div class="d-flex"><div class="toast-body">${escapeHtml(mensagem)}</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" aria-label="Fechar"></button></div>`;
        toast.querySelector('.btn-close').addEventListener('click', () => toast.remove());
        document.getElementById('toast-container').appendChild(toast);
        setTimeout(() => toast.remove(), 5000);
    }

    function alternarTipoVenda() {
        emitirNotaFiscal = !emitirNotaFiscal;
        if (emitirNotaFiscal) {
            badgeTipoVenda.classList.remove('interno');
            badgeTipoVenda.classList.add('fiscal');
            badgeTipoVendaTexto.textContent = 'COM NOTA FISCAL';
        } else {
            badgeTipoVenda.classList.remove('fiscal');
            badgeTipoVenda.classList.add('interno');
            badgeTipoVendaTexto.textContent = 'CONTROLE INTERNO';
        }
    }
    badgeTipoVenda.addEventListener('click', alternarTipoVenda);

    function buscarSugestoes(termo) {
        const termoLimpo = termo.trim().toLowerCase();
        if (!termoLimpo) return [];
        return catalogo.filter(p =>
            (p.codigoBarras && p.codigoBarras.toLowerCase() === termoLimpo) ||
            p.nome.toLowerCase().includes(termoLimpo)
        ).slice(0, 8);
    }

    function renderizarSugestoes(itens) {
        sugestaoAtiva = -1;
        if (itens.length === 0) {
            sugestoesEl.style.display = 'none';
            sugestoesEl.innerHTML = '';
            return;
        }
        sugestoesEl.innerHTML = itens.map((p, i) =>
            `<div class="item-sugestao" data-index="${i}" data-id="${p.id}">
                <div class="fw-semibold">${escapeHtml(p.nome)}</div>
                <div class="small text-muted">${escapeHtml(p.codigoBarras) || 'sem código'} · ${formatarMoeda(p.precoVendaBase)} · estoque: ${p.estoqueAtual}</div>
            </div>`
        ).join('');
        sugestoesEl.style.display = 'block';
        [...sugestoesEl.querySelectorAll('.item-sugestao')].forEach(el => {
            el.addEventListener('click', () => {
                adicionarAoCarrinho(el.dataset.id);
                buscaInput.value = '';
                sugestoesEl.style.display = 'none';
                buscaInput.focus();
            });
        });
    }

    buscaInput.addEventListener('input', () => renderizarSugestoes(buscarSugestoes(buscaInput.value)));

    buscaInput.addEventListener('keydown', (e) => {
        const opcoes = sugestoesEl.querySelectorAll('.item-sugestao');
        if (e.key === 'ArrowDown' && opcoes.length) {
            e.preventDefault();
            sugestaoAtiva = Math.min(sugestaoAtiva + 1, opcoes.length - 1);
            opcoes.forEach((el, i) => el.classList.toggle('ativo', i === sugestaoAtiva));
        } else if (e.key === 'ArrowUp' && opcoes.length) {
            e.preventDefault();
            sugestaoAtiva = Math.max(sugestaoAtiva - 1, 0);
            opcoes.forEach((el, i) => el.classList.toggle('ativo', i === sugestaoAtiva));
        } else if (e.key === 'Enter') {
            e.preventDefault();
            const termo = buscaInput.value.trim();
            if (!termo) return;

            if (sugestaoAtiva >= 0 && opcoes[sugestaoAtiva]) {
                adicionarAoCarrinho(opcoes[sugestaoAtiva].dataset.id);
            } else {
                // Bipe de código de barras: match exato direto, sem precisar navegar sugestões.
                const exato = catalogo.find(p => p.codigoBarras && p.codigoBarras.toLowerCase() === termo.toLowerCase());
                if (exato) {
                    adicionarAoCarrinho(exato.id);
                } else if (opcoes.length === 1) {
                    adicionarAoCarrinho(opcoes[0].dataset.id);
                } else {
                    mostrarToast('Produto não encontrado.', 'aviso');
                    return;
                }
            }
            buscaInput.value = '';
            sugestoesEl.style.display = 'none';
        }
    });

    document.addEventListener('click', (e) => {
        if (!sugestoesEl.contains(e.target) && e.target !== buscaInput) {
            sugestoesEl.style.display = 'none';
        }
    });

    function adicionarAoCarrinho(produtoId) {
        const produto = catalogo.find(p => p.id === produtoId);
        if (!produto) return;

        const existente = carrinho.get(produtoId);
        const quantidadeAtual = existente ? existente.quantidade : 0;
        const tipoPreco = existente ? existente.tipoPreco : 'BALCAO';
        const fator = fatorConversao(produto, tipoPreco);

        if ((quantidadeAtual + 1) * fator > produto.estoqueAtual) {
            mostrarToast(`Estoque insuficiente para "${produto.nome}" (disponível: ${produto.estoqueAtual}).`, 'aviso');
            return;
        }

        carrinho.set(produtoId, { produto, quantidade: quantidadeAtual + 1, tipoPreco });
        renderizarCarrinho();
    }

    function alterarQuantidade(produtoId, delta) {
        const item = carrinho.get(produtoId);
        if (!item) return;
        const novaQuantidade = item.quantidade + delta;
        const fator = fatorConversao(item.produto, item.tipoPreco);
        if (novaQuantidade <= 0) {
            carrinho.delete(produtoId);
        } else if (novaQuantidade * fator > item.produto.estoqueAtual) {
            mostrarToast(`Estoque insuficiente para "${item.produto.nome}" (disponível: ${item.produto.estoqueAtual}).`, 'aviso');
            return;
        } else {
            item.quantidade = novaQuantidade;
        }
        renderizarCarrinho();
    }

    function alternarTipoPrecoItem(produtoId) {
        const item = carrinho.get(produtoId);
        if (!item) return;
        const novoTipo = item.tipoPreco === 'CAIXA' ? 'BALCAO' : 'CAIXA';
        const novoFator = fatorConversao(item.produto, novoTipo);
        if (item.quantidade * novoFator > item.produto.estoqueAtual) {
            mostrarToast(`Estoque insuficiente para vender "${item.produto.nome}" por caixa nessa quantidade.`, 'aviso');
            return;
        }
        item.tipoPreco = novoTipo;
        renderizarCarrinho();
    }

    function removerItem(produtoId) {
        carrinho.delete(produtoId);
        renderizarCarrinho();
    }

    function renderizarCarrinho() {
        if (carrinho.size === 0) {
            carrinhoCorpo.innerHTML = '';
            carrinhoCorpo.appendChild(carrinhoVazioRow);
            resumoItens.textContent = '0';
            totalVendaEl.textContent = formatarMoeda(0);
            return;
        }

        let total = 0;
        let totalItens = 0;
        carrinhoCorpo.innerHTML = '';
        carrinho.forEach((item, produtoId) => {
            const precoUnit = precoParaTipo(item.produto, item.tipoPreco);
            const subtotal = precoUnit * item.quantidade;
            total += subtotal;
            totalItens += item.quantidade;

            const podeVenderPorCaixa = (item.produto.quantidadePorCaixa || 1) > 1;

            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>${escapeHtml(item.produto.nome)}</td>
                <td class="text-center">
                    ${podeVenderPorCaixa
                        ? `<button type="button" class="btn btn-sm btn-outline-warning btn-tipo-preco" title="Alternar Unidade/Caixa">${item.tipoPreco === 'CAIXA' ? 'Cx' : 'Un'}</button>`
                        : '<span class="text-muted small">Un</span>'}
                </td>
                <td class="text-center">
                    <div class="d-inline-flex align-items-center gap-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary btn-menos">−</button>
                        <span>${item.quantidade}</span>
                        <button type="button" class="btn btn-sm btn-outline-secondary btn-mais">+</button>
                    </div>
                </td>
                <td class="text-end">${formatarMoeda(precoUnit)}</td>
                <td class="text-end">${formatarMoeda(subtotal)}</td>
                <td><button type="button" class="btn btn-sm btn-outline-danger btn-remover"><i class="bi bi-trash"></i></button></td>
            `;
            tr.querySelector('.btn-menos').addEventListener('click', () => alterarQuantidade(produtoId, -1));
            tr.querySelector('.btn-mais').addEventListener('click', () => alterarQuantidade(produtoId, 1));
            tr.querySelector('.btn-remover').addEventListener('click', () => removerItem(produtoId));
            const btnTipoPreco = tr.querySelector('.btn-tipo-preco');
            if (btnTipoPreco) btnTipoPreco.addEventListener('click', () => alternarTipoPrecoItem(produtoId));
            carrinhoCorpo.appendChild(tr);
        });

        resumoItens.textContent = totalItens.toString();
        totalVendaEl.textContent = formatarMoeda(total);
    }

    async function finalizarVenda() {
        if (carrinho.size === 0) {
            mostrarToast('Carrinho vazio.', 'aviso');
            return;
        }

        if (metodoPagamentoSelect.value === 'FIADO' && !clienteFiadoSelect.value) {
            mostrarToast('Selecione um cliente para venda fiado.', 'aviso');
            return;
        }

        btnFinalizar.disabled = true;
        try {
            const payload = {
                itens: [...carrinho.values()].map(i => ({ produtoId: i.produto.id, quantidade: i.quantidade, tipoPreco: i.tipoPreco })),
                emitirNotaFiscal,
                metodoPagamento: metodoPagamentoSelect.value,
                clienteId: metodoPagamentoSelect.value === 'FIADO' ? clienteFiadoSelect.value : null
            };

            const resposta = await fetch('/Caixa/Index?handler=ProcessarVenda', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-TOKEN': antiforgeryToken
                },
                body: JSON.stringify(payload)
            });

            const resultado = await resposta.json();

            if (resposta.ok && resultado.sucesso) {
                mostrarToast('Venda finalizada com sucesso!', 'sucesso');
                carrinho.clear();
                renderizarCarrinho();
                buscaInput.focus();
            } else {
                mostrarToast(resultado.mensagem ?? 'Não foi possível finalizar a venda.', 'erro');
            }
        } catch {
            mostrarToast('Falha de comunicação com o servidor. Tente novamente.', 'erro');
        } finally {
            btnFinalizar.disabled = false;
        }
    }
    btnFinalizar.addEventListener('click', finalizarVenda);

    document.addEventListener('keydown', (e) => {
        if (e.key === 'F2') {
            e.preventDefault();
            alternarTipoVenda();
        } else if (e.key === 'F8') {
            e.preventDefault();
            buscaInput.focus();
            buscaInput.select();
        } else if (e.key === 'F10') {
            e.preventDefault();
            finalizarVenda();
        }
    });

    buscaInput.focus();
})();
</script>
