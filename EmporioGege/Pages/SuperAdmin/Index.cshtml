@page
@model EmporioGege.Pages.SuperAdmin.IndexModel
@{
    ViewData["Title"] = "God Mode - Dashboard Geral";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-light mb-1">👑 God Mode</h2>
            <p class="text-muted small mb-0">Visão analítica global do ecossistema e gerenciamento de licenças de adegas.</p>
        </div>
        <a asp-page="/SuperAdmin/Adegas/Editar" class="btn btn-warning btn-sm fw-medium d-flex align-items-center gap-2">
            <i class="bi bi-plus-circle-fill"></i> Nova Licença / Adega
        </a>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card card-custom p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small text-uppercase fw-bold" style="font-size: 0.75rem;">Adegas Clientes</span>
                        <h3 class="fw-bold text-white mt-1 mb-0">@Model.TotalLojas</h3>
                    </div>
                    <div class="bg-warning bg-opacity-10 text-warning p-3 rounded-3">
                        <i class="bi bi-building fs-4"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card card-custom p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small text-uppercase fw-bold" style="font-size: 0.75rem;">Licenças Ativas</span>
                        <h3 class="fw-bold text-success mt-1 mb-0">@Model.LicencasAtivas</h3>
                    </div>
                    <div class="bg-success bg-opacity-10 text-success p-3 rounded-3">
                        <i class="bi bi-shield-check fs-4"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card card-custom p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small text-uppercase fw-bold" style="font-size: 0.75rem;">Total Usuários</span>
                        <h3 class="fw-bold text-info mt-1 mb-0">@Model.TotalUsuarios</h3>
                    </div>
                    <div class="bg-info bg-opacity-10 text-info p-3 rounded-3">
                        <i class="bi bi-people fs-4"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card card-custom p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small text-uppercase fw-bold" style="font-size: 0.75rem;">Faturamento Geral</span>
                        <h3 class="fw-bold text-warning mt-1 mb-0">R$ @Model.FaturamentoGlobal.ToString("N2")</h3>
                    </div>
                    <div class="bg-warning bg-opacity-10 text-warning p-3 rounded-3">
                        <i class="bi bi-currency-dollar fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card card-custom">
        <div class="card-header bg-transparent border-bottom border-secondary border-opacity-25 p-4 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold text-white mb-0"><i class="bi bi-hdd-network-fill me-2 text-warning"></i>Licenças Ativas no Sistema</h5>
            <span class="badge bg-warning text-dark fw-bold" style="font-size: 0.7rem;">AMBIENTE CORE</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0 align-middle" style="background: transparent;">
                    <thead>
                        <tr class="text-muted small" style="border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 0.8rem;">
                            <th class="ps-4 py-3">Adega / Tenant</th>
                            <th>Identificador (Tenant ID)</th>
                            <th>Responsável</th>
                            <th>Status da Assinatura</th>
                            <th class="pe-4 text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Lojas.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">Nenhuma loja cadastrada ainda.</td>
                            </tr>
                        }
                        @foreach (var loja in Model.Lojas)
                        {
                            var badgeClasse = loja.StatusLicenca == "ativo"
                                ? "bg-success bg-opacity-10 text-success border border-success border-opacity-25"
                                : "bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25";
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.02);">
                                <td class="ps-4 d-flex align-items-center gap-3 py-3">
                                    <div class="bg-secondary bg-opacity-25 text-warning rounded-3 d-flex align-items-center justify-content-center" style="width: 42px; height: 42px;">
                                        <i class="bi bi-shop fs-5"></i>
                                    </div>
                                    <div>
                                        <div class="fw-semibold text-white">@loja.NomeFantasia</div>
                                        <div class="text-muted" style="font-size: 0.75rem;">@loja.CidadeEstado</div>
                                    </div>
                                </td>
                                <td class="text-monospace text-muted small">@loja.Id</td>
                                <td>@loja.NomeRepresentante</td>
                                <td><span class="badge @badgeClasse px-2 py-1" style="font-size: 0.7rem;">@loja.StatusLicenca.ToUpperInvariant()</span></td>
                                <td class="pe-4 text-end">
                                    <a asp-page="/SuperAdmin/Adegas/Editar" asp-route-id="@loja.Id" class="btn btn-sm btn-outline-light border-0 opacity-70 hover-opacity-100"><i class="bi bi-sliders"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>      