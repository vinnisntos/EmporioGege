@page "{id:guid?}"
@model EmporioGege.Pages.SuperAdmin.Adegas.EditarModel
@{
    ViewData["Title"] = Model.Id is null ? "Nova Loja" : "Editar Loja";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-white fw-bold">@ViewData["Title"]</h1>
    <a asp-page="Index" class="btn btn-outline-light btn-sm"><i class="bi bi-arrow-left me-1"></i> Voltar</a>
</div>

@if (!string.IsNullOrEmpty(Model.MensagemErro))
{
    <div class="alert alert-danger">@Model.MensagemErro</div>
}
@if (!string.IsNullOrEmpty(Model.MensagemSucesso))
{
    <div class="alert alert-success">@Model.MensagemSucesso</div>
}

<form method="post" class="card card-custom p-4" style="max-width: 640px;">
    <div class="row g-3">
        <div class="col-12">
            <label asp-for="NomeFantasia" class="form-label small text-muted">Nome fantasia</label>
            <input asp-for="NomeFantasia" class="form-control" placeholder="Ex.: Adega do Zé" />
            <span asp-validation-for="NomeFantasia" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="NomeRepresentante" class="form-label small text-muted">Nome do responsável/dono</label>
            <input asp-for="NomeRepresentante" class="form-control" />
            <span asp-validation-for="NomeRepresentante" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="CpfRgDono" class="form-label small text-muted">CPF/RG do dono</label>
            <input asp-for="CpfRgDono" class="form-control" />
            <span asp-validation-for="CpfRgDono" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Cnpj" class="form-label small text-muted">CNPJ</label>
            <input asp-for="Cnpj" class="form-control" />
            <span asp-validation-for="Cnpj" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="CidadeEstado" class="form-label small text-muted">Cidade/UF</label>
            <input asp-for="CidadeEstado" class="form-control" placeholder="Ex.: Sorocaba - SP" />
            <span asp-validation-for="CidadeEstado" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="TelefoneDono" class="form-label small text-muted">Telefone do dono</label>
            <input asp-for="TelefoneDono" class="form-control" />
            <span asp-validation-for="TelefoneDono" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="TelefoneEmpresa" class="form-label small text-muted">Telefone da empresa (opcional)</label>
            <input asp-for="TelefoneEmpresa" class="form-control" />
        </div>

        <div class="col-md-6">
            <label asp-for="EmailDono" class="form-label small text-muted">E-mail do dono</label>
            <input asp-for="EmailDono" type="email" class="form-control" />
            <span asp-validation-for="EmailDono" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="EmailEmpresa" class="form-label small text-muted">E-mail da empresa (opcional)</label>
            <input asp-for="EmailEmpresa" type="email" class="form-control" />
            <span asp-validation-for="EmailEmpresa" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="StatusLicenca" class="form-label small text-muted">Status da licença</label>
            <select asp-for="StatusLicenca" class="form-select">
                <option value="ativo">Ativo</option>
                <option value="suspenso">Suspenso</option>
                <option value="cancelado">Cancelado</option>
            </select>
        </div>
        <div class="col-md-6">
            <label asp-for="DataExpiracao" class="form-label small text-muted">Expira em</label>
            <input asp-for="DataExpiracao" type="date" class="form-control" />
            <span asp-validation-for="DataExpiracao" class="text-danger small"></span>
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-warning fw-semibold px-4">Salvar</button>
        <a asp-page="Index" class="btn btn-outline-light">Cancelar</a>
    </div>
</form>

@if (Model.Id is not null)
{
    <div class="card card-custom p-4 mt-4" style="max-width: 640px;">
        <h5 class="text-white fw-semibold mb-3">Assinatura / Cobrança (Asaas)</h5>

        @if (Model.Assinatura?.AsaasSubscriptionId is not null)
        {
            <div class="mb-3">
                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1 me-2">
                    Assinatura criada
                </span>
                <span class="text-muted small">
                    Plano @Model.Assinatura.Plano · R$ @Model.Assinatura.ValorMensalidade?.ToString("N2") /mês ·
                    Licença: @Model.Assinatura.StatusLicenca
                </span>
            </div>
            <p class="text-muted small mb-0">
                Status e vencimento agora são atualizados automaticamente pelo webhook do Asaas
                conforme os pagamentos entram - não edite "Status da licença" manualmente acima
                enquanto a assinatura estiver ativa.
            </p>
        }
        else
        {
            <p class="text-muted small mb-3">
                Nenhuma assinatura criada ainda. Ao criar, o status da licença passa a ser
                atualizado automaticamente pelos pagamentos recebidos no Asaas.
            </p>
            <form method="post" asp-page-handler="CriarAssinatura">
                <div class="row g-3">
                    <div class="col-md-5">
                        <label class="form-label small text-muted">Plano</label>
                        <select asp-for="Plano" class="form-select">
                            <option value="">Selecione...</option>
                            <option value="start">Start — sugerido R$ 119,00/mês</option>
                            <option value="pro">Pro — sugerido R$ 199,00/mês</option>
                            <option value="enterprise">Enterprise — sugerido R$ 349,00/mês</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="ValorMensalidade" class="form-label small text-muted">Valor mensal combinado</label>
                        <input asp-for="ValorMensalidade" type="number" step="0.01" min="0.01" class="form-control" placeholder="Ex.: 199.00" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="TipoCobranca" class="form-label small text-muted">Forma de pagamento</label>
                        <select asp-for="TipoCobranca" class="form-select">
                            <option value="UNDEFINED">Cliente escolhe</option>
                            <option value="PIX">Pix</option>
                            <option value="BOLETO">Boleto</option>
                            <option value="CREDIT_CARD">Cartão de crédito</option>
                        </select>
                    </div>
                </div>
                <button type="submit" class="btn btn-outline-warning fw-semibold px-4 mt-3">
                    <i class="bi bi-credit-card me-1"></i> Criar assinatura no Asaas
                </button>
            </form>
        }
    </div>
}
