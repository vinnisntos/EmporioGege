@page
@model EmporioGege.Pages.SuperAdmin.Adegas.IndexModel
@{
    ViewData["Title"] = "Adegas / Lojas";
}

<style>
    .badge-status-ativo { background: rgba(25, 135, 84, .15); color: #52d489; border: 1px solid rgba(25, 135, 84, .4); }
    .badge-status-outro { background: rgba(108, 117, 125, .2); color: #adb5bd; border: 1px solid rgba(108, 117, 125, .4); }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 text-white fw-bold"><i class="bi bi-building-gear me-2"></i>Adegas / Lojas</h1>
        <p class="text-muted small mb-0">Cadastro de lojas (tenants) e controle de licença.</p>
    </div>
    <a asp-page="Editar" class="btn btn-warning fw-semibold">
        <i class="bi bi-plus-circle me-1"></i> Nova Loja
    </a>
</div>

@if (!string.IsNullOrEmpty(Model.MensagemSucesso))
{
    <div class="alert alert-success">@Model.MensagemSucesso</div>
}
@if (!string.IsNullOrEmpty(Model.MensagemErro))
{
    <div class="alert alert-danger">@Model.MensagemErro</div>
}

<div class="card card-custom p-3">
    @if (Model.Lojas.Count == 0)
    {
        <p class="text-muted text-center py-4 mb-0">Nenhuma loja cadastrada ainda.</p>
    }
    else
    {
        <table class="table table-dark table-borderless align-middle mb-0">
            <thead>
                <tr class="text-muted small text-uppercase">
                    <th>Loja</th>
                    <th>Responsável</th>
                    <th>Cidade/UF</th>
                    <th>Status</th>
                    <th>Expira em</th>
                    <th style="width:260px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var loja in Model.Lojas)
                {
                    var badgeClasse = loja.StatusLicenca == "ativo" ? "badge-status-ativo" : "badge-status-outro";
                    <tr>
                        <td class="text-white fw-medium">@loja.NomeFantasia</td>
                        <td class="text-muted">@loja.NomeRepresentante</td>
                        <td class="text-muted">@loja.CidadeEstado</td>
                        <td><span class="badge @badgeClasse">@loja.StatusLicenca</span></td>
                        <td class="text-muted small">@loja.DataExpiracao.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end align-items-center gap-2">
                                <form method="post" asp-page-handler="Entrar" asp-route-id="@loja.Id">
                                    <button type="submit" class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-box-arrow-in-right me-1"></i>Entrar
                                    </button>
                                </form>
                                <a asp-page="Editar" asp-route-id="@loja.Id" class="btn btn-sm btn-outline-light">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
