@page
@model EmporioGege.Pages.CadastroLojaModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cadastre sua loja - PendurAi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: radial-gradient(circle at top left, #2c1a04 0%, #0c0c0e 100%);
            min-height: 100vh;
            color: #f8f9fa;
        }

        .auth-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem 1rem;
        }

        .cadastro-card {
            background: rgba(20, 20, 25, 0.85);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            padding: 2.5rem;
            width: 100%;
            max-width: 640px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
        }

        .brand-title {
            font-weight: 800;
            letter-spacing: 1px;
            background: linear-gradient(45deg, #ffffff, #ffc107);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .form-control-custom, .form-select-custom {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
            padding: 0.65rem 1rem;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .form-control-custom:focus, .form-select-custom:focus {
            background: rgba(255, 255, 255, 0.08);
            border-color: #ff9800;
            box-shadow: 0 0 0 3px rgba(255, 152, 0, 0.2);
            color: #fff;
        }

        .btn-cadastrar {
            background: linear-gradient(45deg, #ff9800, #e65100);
            border: none;
            color: #fff;
            padding: 0.85rem;
            font-weight: 600;
            border-radius: 8px;
            transition: transform 0.2s, opacity 0.2s;
        }

        .btn-cadastrar:hover {
            opacity: 0.9;
            color: #fff;
        }

        .text-muted-custom {
            color: #a0a0aa;
            font-size: 0.875rem;
        }

        .validation-error {
            font-size: 0.8rem;
            color: #ef4444;
            margin-top: 0.25rem;
            display: block;
        }

        .plano-opcao, .pagamento-opcao {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            padding: 0.85rem 1rem;
            cursor: pointer;
            transition: border-color 0.2s ease, background 0.2s ease;
        }

        .plano-opcao:hover, .pagamento-opcao:hover {
            border-color: rgba(255, 193, 7, 0.4);
        }

        input[type="radio"]:checked ~ .plano-opcao,
        .plano-opcao:has(input[type="radio"]:checked),
        .pagamento-opcao:has(input[type="radio"]:checked) {
            border-color: #ffc107;
            background: rgba(255, 193, 7, 0.08);
        }

        .plano-preco {
            font-weight: 700;
            color: #ffc107;
        }

        .success-icon {
            font-size: 3rem;
            color: #28a745;
        }
    </style>
</head>
<body>

    <div class="auth-wrapper">
        <div class="cadastro-card">
            @if (Model.ExibirSucesso)
            {
                <div class="text-center">
                    <i class="bi bi-check-circle-fill success-icon mb-3"></i>
                    <h2 class="brand-title mb-3">Cadastro Recebido</h2>
                    <p class="text-muted-custom mx-auto" style="font-size: 0.95rem;">@Model.MensagemSucesso</p>
                    <a asp-page="/Index" class="btn btn-cadastrar mt-3 px-4">Voltar para o site institucional</a>
                </div>
            }
            else
            {
                <h2 class="brand-title mb-1 text-center">Cadastre sua loja</h2>
                <p class="text-muted-custom mb-4 text-center">Crie sua conta no PendurAi em poucos minutos</p>

                @if (!string.IsNullOrEmpty(Model.MensagemErro))
                {
                    <div class="alert alert-danger py-2 px-3 text-start mb-3" role="alert" style="font-size: 0.875rem; background: rgba(239, 68, 68, 0.1); border-color: rgba(239, 68, 68, 0.2); color: #fca5a5;">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @Model.MensagemErro
                    </div>
                }

                <form method="post" class="text-start">
                    <h6 class="text-muted-custom text-uppercase small fw-bold mb-2">Dados da loja</h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-7">
                            <label asp-for="NomeFantasia" class="form-label text-muted-custom fw-medium">Nome da loja</label>
                            <input asp-for="NomeFantasia" class="form-control form-control-custom" placeholder="Ex.: Adega do João" />
                            <span asp-validation-for="NomeFantasia" class="validation-error"></span>
                        </div>
                        <div class="col-md-5">
                            <label asp-for="Cnpj" class="form-label text-muted-custom fw-medium">CNPJ</label>
                            <input asp-for="Cnpj" class="form-control form-control-custom" placeholder="00.000.000/0001-00" />
                            <span asp-validation-for="Cnpj" class="validation-error"></span>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="CidadeEstado" class="form-label text-muted-custom fw-medium">Cidade / Estado</label>
                            <input asp-for="CidadeEstado" class="form-control form-control-custom" placeholder="Ex.: Sorocaba / SP" />
                            <span asp-validation-for="CidadeEstado" class="validation-error"></span>
                        </div>
                    </div>

                    <h6 class="text-muted-custom text-uppercase small fw-bold mb-2 mt-4">Seus dados (login de administrador)</h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-7">
                            <label asp-for="NomeRepresentante" class="form-label text-muted-custom fw-medium">Nome completo</label>
                            <input asp-for="NomeRepresentante" class="form-control form-control-custom" />
                            <span asp-validation-for="NomeRepresentante" class="validation-error"></span>
                        </div>
                        <div class="col-md-5">
                            <label asp-for="CpfRgDono" class="form-label text-muted-custom fw-medium">CPF/RG</label>
                            <input asp-for="CpfRgDono" class="form-control form-control-custom" />
                            <span asp-validation-for="CpfRgDono" class="validation-error"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="TelefoneDono" class="form-label text-muted-custom fw-medium">Telefone</label>
                            <input asp-for="TelefoneDono" class="form-control form-control-custom" placeholder="(15) 90000-0000" />
                            <span asp-validation-for="TelefoneDono" class="validation-error"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EmailDono" class="form-label text-muted-custom fw-medium">E-mail (será seu login)</label>
                            <input asp-for="EmailDono" type="email" class="form-control form-control-custom" placeholder="seu@email.com" />
                            <span asp-validation-for="EmailDono" class="validation-error"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Senha" class="form-label text-muted-custom fw-medium">Senha</label>
                            <input asp-for="Senha" type="password" class="form-control form-control-custom" placeholder="••••••••" />
                            <span asp-validation-for="Senha" class="validation-error"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ConfirmarSenha" class="form-label text-muted-custom fw-medium">Confirmar senha</label>
                            <input asp-for="ConfirmarSenha" type="password" class="form-control form-control-custom" placeholder="••••••••" />
                            <span asp-validation-for="ConfirmarSenha" class="validation-error"></span>
                        </div>
                    </div>

                    <h6 class="text-muted-custom text-uppercase small fw-bold mb-2 mt-4">Plano</h6>
                    <div class="row g-2 mb-3">
                        <div class="col-md-4">
                            <label class="plano-opcao d-flex justify-content-between align-items-center w-100 mb-0">
                                <span>
                                    <input type="radio" asp-for="Plano" value="start" class="form-check-input me-2" /> Start
                                </span>
                                <span class="plano-preco">R$ 119</span>
                            </label>
                        </div>
                        <div class="col-md-4">
                            <label class="plano-opcao d-flex justify-content-between align-items-center w-100 mb-0">
                                <span>
                                    <input type="radio" asp-for="Plano" value="pro" class="form-check-input me-2" /> Pro
                                </span>
                                <span class="plano-preco">R$ 199</span>
                            </label>
                        </div>
                        <div class="col-md-4">
                            <label class="plano-opcao d-flex justify-content-between align-items-center w-100 mb-0">
                                <span>
                                    <input type="radio" asp-for="Plano" value="enterprise" class="form-check-input me-2" /> Enterprise
                                </span>
                                <span class="plano-preco">R$ 349</span>
                            </label>
                        </div>
                    </div>
                    <span asp-validation-for="Plano" class="validation-error mb-3 d-block"></span>

                    <h6 class="text-muted-custom text-uppercase small fw-bold mb-2 mt-4">Forma de pagamento</h6>
                    <div class="row g-2 mb-4">
                        <div class="col-md-4">
                            <label class="pagamento-opcao d-flex align-items-center w-100 mb-0">
                                <input type="radio" asp-for="TipoCobranca" value="PIX" class="form-check-input me-2" /> Pix
                            </label>
                        </div>
                        <div class="col-md-4">
                            <label class="pagamento-opcao d-flex align-items-center w-100 mb-0">
                                <input type="radio" asp-for="TipoCobranca" value="BOLETO" class="form-check-input me-2" /> Boleto
                            </label>
                        </div>
                        <div class="col-md-4">
                            <label class="pagamento-opcao d-flex align-items-center w-100 mb-0">
                                <input type="radio" asp-for="TipoCobranca" value="CREDIT_CARD" class="form-check-input me-2" /> Cartão
                            </label>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mb-3">
                        <button type="submit" class="btn btn-cadastrar">Criar minha loja</button>
                    </div>

                    <div class="text-center">
                        <a asp-page="/Index" class="text-decoration-none text-muted-custom" style="transition: color 0.2s;" onmouseover="this.style.color='#ff9800'" onmouseout="this.style.color='#a0a0aa'">
                            ← Voltar para o site institucional
                        </a>
                    </div>
                </form>
            }
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
