@page
@model EmporioGege.Pages.Auth.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - PendurAi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: radial-gradient(circle at top left, #2c1a04 0%, #0c0c0e 100%);
            min-height: 100vh;
            color: #f8f9fa;
        }

        .auth-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .login-card {
            background: rgba(20, 20, 25, 0.85);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            padding: 2.5rem;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
        }

        .brand-title {
            font-weight: 800;
            letter-spacing: 1px;
            background: linear-gradient(45deg, #ffffff, #ffc107);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .form-control-custom {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
            padding: 0.75rem 1rem;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .form-control-custom:focus {
            background: rgba(255, 255, 255, 0.08);
            border-color: #ff9800;
            box-shadow: 0 0 0 3px rgba(255, 152, 0, 0.2);
            color: #fff;
        }

        .btn-login {
            background: linear-gradient(45deg, #ff9800, #e65100);
            border: none;
            color: #fff;
            padding: 0.75rem;
            font-weight: 600;
            border-radius: 8px;
            transition: transform 0.2s, opacity 0.2s;
        }

        .btn-login:hover {
            opacity: 0.9;
            color: #fff;
        }

        .btn-login:active {
            transform: scale(0.98);
        }

        .text-muted-custom {
            color: #a0a0aa;
            font-size: 0.875rem;
        }

        .validation-error {
            font-size: 0.8rem;
            color: #ef4444;
            margin-top: 0.25rem;
            display: block;
        }
    </style>
</head>
<body>

    <div class="auth-wrapper">
        <div class="login-card text-center">
            <h2 class="brand-title mb-1">PENDURAI</h2>
            <p class="text-muted-custom mb-4">Gestão Integrada &amp; PDV</p>

            @if (!string.IsNullOrEmpty(Model.MensagemErro))
            {
                <div class="alert alert-danger py-2 px-3 text-start mb-3" role="alert" style="font-size: 0.875rem; background: rgba(239, 68, 68, 0.1); border-color: rgba(239, 68, 68, 0.2); color: #fca5a5;">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @Model.MensagemErro
                </div>
            }

            <form method="post" class="text-start">
                <div class="mb-3">
                    <label asp-for="Email" class="form-label text-muted-custom fw-medium">E-mail</label>
                    <input asp-for="Email" type="email" class="form-control form-control-custom" placeholder="seu@email.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="validation-error"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Senha" class="form-label text-muted-custom fw-medium">Senha</label>
                    <input asp-for="Senha" type="password" class="form-control form-control-custom" placeholder="••••••••" />
                    <span asp-validation-for="Senha" class="validation-error"></span>
                </div>

                <div class="d-grid gap-2 mb-3">
                    <button type="submit" class="btn btn-login">Entrar no Sistema</button>
                </div>
            </form>

            <div class="mt-4">
                <a asp-page="/Index" class="text-decoration-none text-muted-custom" style="transition: color 0.2s;" onmouseover="this.style.color='#ff9800'" onmouseout="this.style.color='#a0a0aa'">
                    ← Voltar para o site institucional
                </a>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
